#!/bin/bash
# Hook: UserPromptSubmit
# Checks if 2h has elapsed since last ingest, triggers background ingest if so (AC2).
# Timer updates unconditionally — server-side offset handles deduplication.
# Graceful degradation: exits 0 if memory server is unreachable.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

read_hook_input

CWD=$(get_field "cwd" 2>/dev/null || echo "")
PROJECT=$(echo "$CWD" | xargs basename 2>/dev/null || echo "unknown")
# Sanitize project name to safe URL chars
PROJECT=$(echo "$PROJECT" | tr -cd 'a-zA-Z0-9_-')
PROJECT="${PROJECT:-unknown}"

SESSION_ID=$(get_field "session_id" 2>/dev/null || echo "hook-$(date +%s)")
LAST_INGEST_FILE="${MEMORY_STATE_DIR}/memorypalace-last-ingest-${PROJECT}"
INGEST_INTERVAL_SECONDS=7200  # 2 hours

# Check timer state
NOW=$(date +%s)
LAST_INGEST=0
if [[ -f "$LAST_INGEST_FILE" ]]; then
    LAST_INGEST=$(cat "$LAST_INGEST_FILE" 2>/dev/null || echo "0")
    # Guard against corrupt timer file (non-numeric content)
    if ! [[ "$LAST_INGEST" =~ ^[0-9]+$ ]]; then
        _debug "Corrupt timer file, resetting"
        LAST_INGEST=0
    fi
fi

ELAPSED=$((NOW - LAST_INGEST))

if [[ "$ELAPSED" -ge "$INGEST_INTERVAL_SECONDS" ]]; then
    _debug "2h elapsed since last ingest ($ELAPSED seconds) — gathering session notes"
    NOTES=$(gather_session_notes "$CWD")
    if [[ -n "$NOTES" ]]; then
        PAYLOAD=$(build_ingest_payload "$PROJECT" "$SESSION_ID" "$NOTES" "timer" "")
        call_memory_server "/ingest" "POST" "$PAYLOAD" >/dev/null 2>&1 &
    else
        _debug "No session notes found — skipping ingest"
    fi
    # Update timer unconditionally — server offset handles dedup on restart
    echo "$NOW" > "$LAST_INGEST_FILE"
fi

exit 0
