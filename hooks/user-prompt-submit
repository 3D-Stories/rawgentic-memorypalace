#!/bin/bash
# Hook: UserPromptSubmit
# Smart-gated auto-recall: extracts prompt, applies gates, POSTs to /search.
# Graceful degradation: exits 0 if server unreachable or gates block recall.
# NO set -e — curl/jq non-zero must not abort silently.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

# Read full hook input from stdin
HOOK_INPUT=$(cat)

# Extract prompt from hook input
PROMPT=$(echo "$HOOK_INPUT" | jq -r '.prompt // empty' 2>/dev/null) || true

# Resolve project
CWD=$(echo "$HOOK_INPUT" | jq -r '.cwd // empty' 2>/dev/null) || true
PROJECT=$(resolve_project "$CWD")

_debug "UserPromptSubmit: project=$PROJECT prompt_len=${#PROMPT}"

# Gate: should we search at all?
if ! should_search "$PROMPT" "$PROJECT"; then
    _debug "UserPromptSubmit: gated out — no search"
    exit 0
fi

# Gate: is server healthy?
if ! server_is_healthy; then
    _debug "UserPromptSubmit: server not healthy — skipping search"
    exit 0
fi

# POST full hook input to /search with thresholds
# The server's _parse_body() extracts .prompt from the JSON body
SEARCH_RESPONSE=$(echo "$HOOK_INPUT" | \
    curl --silent --fail --connect-timeout 2 --max-time 8 \
        -X POST \
        -H "Content-Type: application/json" \
        -H "X-Similarity-Threshold: ${RECALL_SIMILARITY_THRESHOLD}" \
        -H "X-Max-Results: ${RECALL_MAX_RESULTS}" \
        --data-binary @- \
        "${MEMORY_SERVER_URL}/search" 2>/dev/null) || true

if [[ -n "$SEARCH_RESPONSE" ]]; then
    # Validate JSON before outputting
    if echo "$SEARCH_RESPONSE" | jq empty 2>/dev/null; then
        ADDITIONAL=$(echo "$SEARCH_RESPONSE" | jq -r '.additionalContext // empty' 2>/dev/null) || true
        if [[ -n "$ADDITIONAL" ]]; then
            _debug "UserPromptSubmit: search has additionalContext, injecting"
            # Claude Code schema: {hookSpecificOutput: {hookEventName: "UserPromptSubmit", additionalContext: <string>}}
            echo "$SEARCH_RESPONSE" | jq '{
                hookSpecificOutput: {
                    hookEventName: "UserPromptSubmit",
                    additionalContext: (.additionalContext // "")
                }
            }'
        else
            _debug "UserPromptSubmit: search empty — skipping injection"
        fi
    else
        _debug "UserPromptSubmit: search returned non-JSON — ignoring"
    fi
else
    _debug "UserPromptSubmit: no search response"
fi

exit 0
