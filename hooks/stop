#!/bin/bash
# Hook: Stop
# Synchronous final flush — calls /ingest to capture remaining session data (AC3).
# Does NOT attempt lazy-start: if server isn't running at stop time, data was
# already ingested by PreCompact/Timer, or will be on next reindex.
# Graceful degradation: exits 0 if memory server is unreachable.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

read_hook_input

CWD=$(get_field "cwd" 2>/dev/null || echo "")
PROJECT=$(echo "$CWD" | xargs basename 2>/dev/null || echo "unknown")
# Sanitize project name to safe URL chars
PROJECT=$(echo "$PROJECT" | tr -cd 'a-zA-Z0-9_-')
PROJECT="${PROJECT:-unknown}"

SESSION_ID=$(get_field "session_id" 2>/dev/null || echo "hook-$(date +%s)")

_debug "Stop event — gathering session notes for synchronous flush"
NOTES=$(gather_session_notes "$CWD")
if [[ -n "$NOTES" ]]; then
    PAYLOAD=$(build_ingest_payload "$PROJECT" "$SESSION_ID" "$NOTES" "stop" "")
    # Synchronous call — but skip lazy-start (no point starting server at shutdown)
    MEMORY_NO_AUTOSTART=1 call_memory_server "/ingest" "POST" "$PAYLOAD" >/dev/null 2>&1 || true
else
    _debug "No session notes found — skipping final flush"
fi

exit 0
