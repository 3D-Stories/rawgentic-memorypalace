#!/bin/bash
# Hook: SessionStart (matcher: startup|resume|compact)
# - On startup/resume: calls /wakeup for context injection
# - On compact: calls /ingest async (PreCompact trigger — AC1)
# Graceful degradation: exits 0 if memory server is unreachable.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

read_hook_input

# Verify mempalace is importable (declared dependency — should be installed)
if ! python3 -c "import mempalace" 2>/dev/null; then
    _debug "WARNING: mempalace not importable — memory backend will be unavailable"
fi

# Determine event type from matcher
EVENT_TYPE=$(get_field "event" 2>/dev/null || echo "startup")

CWD=$(get_field "cwd" 2>/dev/null || echo "")
PROJECT=$(echo "$CWD" | xargs basename 2>/dev/null || echo "unknown")
# Sanitize project name to safe URL chars
PROJECT=$(echo "$PROJECT" | tr -cd 'a-zA-Z0-9_-')
PROJECT="${PROJECT:-unknown}"

SESSION_ID=$(get_field "session_id" 2>/dev/null || echo "hook-$(date +%s)")

case "$EVENT_TYPE" in
    compact)
        # PreCompact: gather content and fire-and-forget async ingest
        _debug "PreCompact event — gathering session notes for async ingest"
        NOTES=$(gather_session_notes "$CWD")
        if [[ -n "$NOTES" ]]; then
            PAYLOAD=$(build_ingest_payload "$PROJECT" "$SESSION_ID" "$NOTES" "precompact" "")
            call_memory_server "/ingest" "POST" "$PAYLOAD" >/dev/null 2>&1 &
            disown 2>/dev/null || true
        else
            _debug "No session notes found — skipping ingest"
        fi
        ;;
    startup|resume|*)
        # Wake-up: fetch context for session injection
        _debug "SessionStart event — fetching wake-up context"
        CONTEXT=$(call_memory_server "/wakeup?project=${PROJECT}" 2>/dev/null || echo "")
        # Validate JSON before injecting into hook output
        if [[ -n "$CONTEXT" ]] && echo "$CONTEXT" | jq empty 2>/dev/null; then
            echo "{\"additionalContext\": $CONTEXT}"
        fi
        ;;
esac

exit 0
