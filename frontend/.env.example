# Frontend Docker Compose configuration
# Copy this file to .env and edit paths to match your setup.
#
# See: docs/frontend-decision.md for architecture context.

# Path to the native ChromaDB backend's data directory.
# This is the ChromaDB persist directory used by the native (non-MemPalace) backend.
# REQUIRED — docker compose will error if not set.
NATIVE_CHROMADB_PATH=~/claude_docs/memory/chromadb

# Path to the MemPalace backend's ChromaDB data directory.
# Default: ~/.mempalace/palace (the mempalace library's default location).
MEMPALACE_CHROMADB_PATH=~/.mempalace/palace
